# CAD SYSTEM - ОБЩИЙ КОНФИГУРАЦИОННЫЙ ФАЙЛ
# =============================================================================
# Этот файл содержит все переменные окружения для Frontend и Backend
# Скопируйте этот файл в .env и заполните своими значениями
# =============================================================================

# =============================================================================
# БАЗОВАЯ КОНФИГУРАЦИЯ ПРИЛОЖЕНИЯ
# =============================================================================
NODE_ENV=development

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# URL фронтенда (для CORS и редиректов)
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# URL бэкенда API (тот же порт что и frontend - проксируется через nginx/next)
BACKEND_URL=http://localhost:3000
BACKEND_PORT=3000

# API URL для frontend (проксируется через Next.js rewrites)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=cad
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cadadministratorpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Полный URL для Prisma (backend)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# =============================================================================
# REDIS CONFIGURATION (опционально)
# =============================================================================
# REDIS_PASSWORD=your_redis_password
# REDIS_URL="redis://:${REDIS_PASSWORD}@localhost:6379"

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Разрешенные домены (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3030

# =============================================================================
# АВТОРИЗАЦИЯ / AUTHENTICATION
# =============================================================================
# Тип авторизации: local, discord, ips, all
AUTH_TYPE=all

# =============================================================================
# DISCORD OAUTH CONFIGURATION
# =============================================================================
# Discord App Credentials (получить на https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token

# Discord OAuth Redirect URI
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# ID Discord сервера (для бота)
DISCORD_GUILD_ID=your_guild_id

# ID канала для логов
DISCORD_LOG_CHANNEL_ID=your_log_channel_id

# Публичный Client ID для frontend
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# =============================================================================
# IPS INVISION COMMUNITY CONFIGURATION
# =============================================================================
# IPS REST API Configuration
IPS_API_URL=https://your-forum.com/api
IPS_API_KEY=your_ips_api_key
IPS_CLIENT_ID=your_ips_client_id
IPS_CLIENT_SECRET=your_ips_client_secret
IPS_REDIRECT_URI=http://localhost:3030/api/auth/ips/callback

# =============================================================================
# EMAIL CONFIGURATION (опционально)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000

# =============================================================================
# FEATURE FLAGS (Frontend)
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# =============================================================================
# THIRD-PARTY INTEGRATIONS (Frontend)
# =============================================================================
# Google Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_ga_id

# Sentry
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Map API
# NEXT_PUBLIC_MAP_API_KEY=your_map_api_key

# =============================================================================
# BUILD CONFIGURATION (Frontend)
# =============================================================================
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# SSL CONFIGURATION (для production)
# =============================================================================
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
